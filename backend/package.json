{
  "name": "agenda-dinamica-backend",
  "version": "1.0.0",
  "description": "Backend API for AgendaDiaria multi-user authentication system",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "watch": "tsc --watch",
    "test": "npm run build && node --test dist/**/*.test.js",
    "test:db": "node test-db-connection.js",
    "verify:db:permissions": "node verify-db-permissions.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "migrate": "node-pg-migrate --envPath .env --config-file migrations.config.json",
    "migrate:up": "node-pg-migrate up --envPath .env --config-file migrations.config.json",
    "migrate:down": "node-pg-migrate down --envPath .env --config-file migrations.config.json",
    "migrate:create": "node-pg-migrate create --envPath .env --config-file migrations.config.json"
  },
  "keywords": [
    "api",
    "authentication",
    "notes",
    "agenda"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.11.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.13.1",
    "pg-pool": "^3.14.0"
  }
}
